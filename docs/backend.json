
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive profile information for Al Batul members including partner preferences and lifestyle.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dob": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "mobileNumber": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "maritalStatus": { "type": "string", "enum": ["Single", "Divorced", "Widowed"] },
        "sect": { "type": "string", "enum": ["Sunni", "Shia", "Other"] },
        "lifestyle": { "type": "string", "enum": ["Moderate", "Religious", "Liberal"] },
        "education": { "type": "string" },
        "occupation": { "type": "string" },
        "income": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "languagesSpoken": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "photoUrl": { "type": "string" },
        "photos": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "idPhotoUrl": { "type": "string", "description": "URL of the submitted government ID." },
        "selfiePhotoUrl": { "type": "string", "description": "URL of the submitted selfie for verification." },
        "about": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Verification status" },
        "role": { "type": "string", "enum": ["user", "admin"], "default": "user" },
        "isSuspended": { "type": "boolean", "default": false },
        "isBanned": { "type": "boolean", "default": false },
        "isProfileComplete": { "type": "boolean", "default": false },
        "membership": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["Free", "Basic", "Silver", "Gold", "Premium"] },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "partnerPreferences": {
          "type": "object",
          "properties": {
            "minAge": { "type": "number" },
            "maxAge": { "type": "number" },
            "sect": { "type": "string" },
            "education": { "type": "string" },
            "location": { "type": "string" },
            "maritalStatus": { "type": "string" },
            "profession": { "type": "string" }
          }
        },
        "settings": {
          "type": "object",
          "properties": {
            "hideProfileFromSearch": { "type": "boolean", "default": false },
            "hideOnlineStatus": { "type": "boolean", "default": false },
            "hideLastActive": { "type": "boolean", "default": false },
            "hidePhotosFromNonPremium": { "type": "boolean", "default": false },
            "notifications": {
              "type": "object",
              "properties": {
                "messages": { "type": "boolean", "default": true },
                "interests": { "type": "boolean", "default": true },
                "interestAccepted": { "type": "boolean", "default": true },
                "matches": { "type": "boolean", "default": true },
                "membership": { "type": "boolean", "default": true },
                "promotional": { "type": "boolean", "default": false }
              }
            }
          }
        },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "age", "gender", "sect", "status", "city", "country", "mobileNumber"]
    },
    "UserBlock": {
      "title": "User Block",
      "description": "Represents a block relationship between two users.",
      "type": "object",
      "properties": {
        "blockerId": { "type": "string" },
        "blockedId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "UserReport": {
      "title": "User Report",
      "description": "A report filed against a user for community violations.",
      "type": "object",
      "properties": {
        "reporterId": { "type": "string" },
        "reportedId": { "type": "string" },
        "reportedName": { "type": "string" },
        "category": { "type": "string", "enum": ["Fake profile", "Harassment", "Inappropriate content", "Spam", "Scammer", "Other"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "reviewed"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "actionTaken": { "type": "string" }
      }
    },
    "MembershipPayment": {
      "title": "Membership Payment",
      "description": "Records of manual payment submissions for membership upgrades.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "plan": { "type": "string", "enum": ["Basic", "Silver", "Gold", "Premium"] },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plan", "amount", "transactionId", "status"]
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores individual user profile data."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Stores user notifications."
    },
    "/blocks/{blockId}": {
      "schema": "UserBlock",
      "description": "Stores blocking relationships."
    },
    "/reports/{reportId}": {
      "schema": "UserReport",
      "description": "Stores community safety reports."
    },
    "/payments/{paymentId}": {
      "schema": "MembershipPayment",
      "description": "Stores manual payment verification requests."
    },
    "/interests/{interestId}": {
      "schema": "InterestRequest",
      "description": "Stores interest requests and matching status."
    },
    "/interests/{interestId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Stores real-time messages for an accepted match conversation."
    },
    "/settings/platform": {
      "schema": "PlatformSettings",
      "description": "Global platform configuration."
    }
  }
}
