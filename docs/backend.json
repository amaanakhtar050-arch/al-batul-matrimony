
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive profile information for Al Batul members including partner preferences.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dob": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "mobileNumber": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "maritalStatus": { "type": "string", "enum": ["Single", "Divorced", "Widowed"] },
        "sect": { "type": "string", "enum": ["Sunni", "Shia", "Other"] },
        "education": { "type": "string" },
        "occupation": { "type": "string" },
        "income": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "languagesSpoken": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "photoUrl": { "type": "string" },
        "photos": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "about": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Verification status" },
        "role": { "type": "string", "enum": ["user", "admin"], "default": "user" },
        "isSuspended": { "type": "boolean", "default": false },
        "isBanned": { "type": "boolean", "default": false },
        "membership": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["Free", "Registration", "Silver", "Gold", "Premium", "Prime"] },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "partnerPreferences": {
          "type": "object",
          "properties": {
            "minAge": { "type": "number" },
            "maxAge": { "type": "number" },
            "sect": { "type": "string" },
            "education": { "type": "string" },
            "location": { "type": "string" }
          }
        },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "age", "gender", "sect", "status", "city", "country", "mobileNumber"]
    },
    "MembershipPayment": {
      "title": "Membership Payment",
      "description": "Records of manual payment submissions for membership upgrades.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "plan": { "type": "string", "enum": ["Registration", "Silver", "Gold", "Premium", "Prime"] },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plan", "amount", "transactionId", "status"]
    },
    "PlatformSettings": {
      "title": "Platform Settings",
      "description": "Global configuration settings for the Al Batul platform.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "registrationEnabled": { "type": "boolean" },
        "upiId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores individual user profile data."
    },
    "/payments/{paymentId}": {
      "schema": "MembershipPayment",
      "description": "Stores manual payment verification requests."
    },
    "/settings/platform": {
      "schema": "PlatformSettings",
      "description": "Global platform configuration."
    }
  }
}
