{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive profile information for Al Batul members including partner preferences and lifestyle.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "dob": { "type": "string", "format": "date" },
        "age": { "type": "number" },
        "mobileNumber": { "type": "string" },
        "whatsAppNumber": { "type": "string" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "maritalStatus": { "type": "string", "enum": ["Single", "Divorced", "Widowed"] },
        "sect": { "type": "string", "enum": ["Sunni", "Shia", "Other"] },
        "lifestyle": { "type": "string", "enum": ["Moderate", "Religious", "Liberal"] },
        "education": { "type": "string" },
        "occupation": { "type": "string" },
        "income": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "languagesSpoken": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "photoUrl": { "type": "string" },
        "photos": { 
          "type": "array",
          "items": { "type": "string" }
        },
        "idPhotoUrl": { "type": "string", "description": "URL of the submitted government ID." },
        "selfiePhotoUrl": { "type": "string", "description": "URL of the submitted selfie for verification." },
        "about": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Verification status" },
        "role": { "type": "string", "enum": ["user", "admin"], "default": "user" },
        "isSuspended": { "type": "boolean", "default": false },
        "isBanned": { "type": "boolean", "default": false },
        "isProfileComplete": { "type": "boolean", "default": false },
        "membership": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["Free", "Basic", "Silver", "Gold", "Premium"] },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "partnerPreferences": {
          "type": "object",
          "properties": {
            "minAge": { "type": "number" },
            "maxAge": { "type": "number" },
            "sect": { "type": "string" },
            "education": { "type": "string" },
            "location": { "type": "string" }
          }
        },
        "lastActiveAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "age", "gender", "sect", "status", "city", "country", "mobileNumber"]
    },
    "MembershipPayment": {
      "title": "Membership Payment",
      "description": "Records of manual payment submissions for membership upgrades.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "plan": { "type": "string", "enum": ["Basic", "Silver", "Gold", "Premium"] },
        "amount": { "type": "number" },
        "transactionId": { "type": "string" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "plan", "amount", "transactionId", "status"]
    },
    "InterestRequest": {
      "title": "Interest Request",
      "description": "Matrimonial interest requests between members.",
      "type": "object",
      "properties": {
        "fromUserId": { "type": "string" },
        "fromUserName": { "type": "string" },
        "toUserId": { "type": "string" },
        "toUserName": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fromUserId", "toUserId", "status"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Individual messages within a private chat conversation.",
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "senderId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "read": { "type": "boolean", "default": false }
      },
      "required": ["text", "senderId", "timestamp"]
    },
    "Notification": {
      "title": "Notification",
      "description": "A notification message for a user.",
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "read": { "type": "boolean", "default": false },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "title", "message", "read", "createdAt"]
    },
    "PlatformSettings": {
      "title": "Platform Settings",
      "description": "Global configuration settings for the Al Batul platform.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "registrationEnabled": { "type": "boolean" },
        "upiId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores individual user profile data."
    },
    "/users/{userId}/notifications/{notificationId}": {
      "schema": "Notification",
      "description": "Stores user notifications."
    },
    "/payments/{paymentId}": {
      "schema": "MembershipPayment",
      "description": "Stores manual payment verification requests."
    },
    "/interests/{interestId}": {
      "schema": "InterestRequest",
      "description": "Stores interest requests and matching status."
    },
    "/interests/{interestId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Stores real-time messages for an accepted match conversation."
    },
    "/settings/platform": {
      "schema": "PlatformSettings",
      "description": "Global platform configuration."
    }
  }
}
