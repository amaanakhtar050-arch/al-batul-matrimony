
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Comprehensive profile information for Al Batul members.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female"] },
        "maritalStatus": { "type": "string" },
        "sect": { "type": "string" },
        "education": { "type": "string" },
        "occupation": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "country": { "type": "string" },
        "photoUrl": { "type": "string" },
        "about": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"], "description": "Approval status for the profile" },
        "role": { "type": "string", "enum": ["user", "admin"], "default": "user" },
        "isSuspended": { "type": "boolean", "default": false },
        "isBanned": { "type": "boolean", "default": false },
        "membership": {
          "type": "object",
          "properties": {
            "plan": { "type": "string", "enum": ["Free", "Gold", "Platinum"] },
            "expiresAt": { "type": "string", "format": "date-time" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "age", "gender", "sect", "status"]
    },
    "MembershipPayment": {
      "title": "Membership Payment",
      "description": "Records of manual payment submissions for membership upgrades.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "plan": { "type": "string", "enum": ["Gold", "Platinum"] },
        "amount": { "type": "number" },
        "transactionId": { "type": "string", "description": "UTR or Transaction Reference Number" },
        "screenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "processedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["userId", "plan", "amount", "transactionId", "status"]
    },
    "PlatformSettings": {
      "title": "Platform Settings",
      "description": "Global configuration settings for the Al Batul platform.",
      "type": "object",
      "properties": {
        "siteName": { "type": "string" },
        "maintenanceMode": { "type": "boolean" },
        "registrationEnabled": { "type": "boolean" },
        "upiId": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Stores individual user profile data."
    },
    "/payments/{paymentId}": {
      "schema": "MembershipPayment",
      "description": "Stores manual payment verification requests."
    },
    "/settings/platform": {
      "schema": "PlatformSettings",
      "description": "Global platform configuration."
    }
  }
}
